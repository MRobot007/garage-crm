# ─── Database ───────────────────────────────────────────────────────────────
# MySQL / MariaDB connection string.
#
# XAMPP (local) default: user "root", NO password, host 127.0.0.1, port 3306.
#   DATABASE_URL="mysql://root:@127.0.0.1:3306/garage_crm"
#
# Production needs a HOSTED MySQL (XAMPP is local-only) — e.g. Railway, Aiven,
# TiDB Cloud, PlanetScale:
#   DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/garage_crm?sslaccept=strict"
DATABASE_URL="mysql://root:@127.0.0.1:3306/garage_crm"

# ─── Auth (login gate) ──────────────────────────────────────────────────────
# The shared password staff type in to open the CRM.
CRM_PASSWORD="changeme"

# Secret used to sign the session cookie. Use a long random string in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="dev-insecure-secret-change-me"
