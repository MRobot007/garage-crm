# ─── Database ───────────────────────────────────────────────────────────────
# MySQL / MariaDB connection string.
#
# XAMPP (local) default: user "root", NO password, host 127.0.0.1, port 3306.
#   DATABASE_URL="mysql://root:@127.0.0.1:3306/garage_crm"
#
# Production needs a HOSTED MySQL (XAMPP is local-only) — e.g. Railway, Aiven,
# TiDB Cloud, PlanetScale:
#   DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/garage_crm?sslaccept=strict"
DATABASE_URL="mysql://root:@127.0.0.1:3306/garage_crm"

# ─── Auth (login gate) ──────────────────────────────────────────────────────
# The shared password staff type in to open the CRM.
CRM_PASSWORD="changeme"

# Secret used to sign the session cookie. Use a long random string in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="dev-insecure-secret-change-me"

# ─── Email (supplier orders) — OPTIONAL ─────────────────────────────────────
# If set, "Send order" emails the supplier directly from the CRM. If unset, the
# CRM falls back to opening your email app with the order pre-written (mailto).
# Gmail example (create an App Password at myaccount.google.com/apppasswords):
#   SMTP_HOST="smtp.gmail.com"
#   SMTP_PORT="587"
#   SMTP_USER="you@gmail.com"
#   SMTP_PASS="your-16-char-app-password"
#   SMTP_FROM="Summit Auto Group <you@gmail.com>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ─── Storefront branding for the customer auto-reply email ──────────────────
# When a website enquirer picks an in-stock accessory + gives their email, the
# CRM emails them "it's in stock — come visit". These control that email's text.
SHOP_NAME="VOZIDEX"
SHOP_HOURS="Mon–Sat, 10:00 AM – 8:00 PM"
SHOP_ADDRESS="VOZIDEX Customs, United States"
SHOP_PHONE=""
